<?xml version="1.0" encoding="utf-8"?>
<!--
  Square canvas + fixed logo bounds; bitmap android:gravity="center" keeps aspect ratio
  (avoids vertical stretch from inset viewports). Height reduced vs wider slot.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item
      android:width="288dp"
      android:height="288dp"
      android:gravity="center">
    <shape android:shape="rectangle">
      <solid android:color="@color/splashscreen_background" />
    </shape>
  </item>
  <item
      android:width="156dp"
      android:height="18dp"
      android:gravity="center">
    <bitmap
        android:gravity="center"
        android:src="@drawable/kochgourmet_logo" />
  </item>
</layer-list>
