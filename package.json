{
  "name": "assetera",
  "main": "./index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "dev:clear": "EXPO_NO_TELEMETRY=1 expo start --clear",
    "dev:android": "EXPO_NO_TELEMETRY=1 expo start --android --clear",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "deploy:netlify": "npm run build:web && npx netlify-cli deploy --dir=dist --prod",
    "deploy:surge": "npm run build:web && cd dist && npx surge",
    "build:web:production": "expo export --platform web --output-dir build",
    "lint": "expo lint",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "androidRelease": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/build/intermediates/res/merged/release/ --reset-cache && rm -rf android/app/src/main/res/drawable-* && rm -rf android/app/src/main/res/raw/* && cd android && ./gradlew assembleRelease && cd .."
  },
